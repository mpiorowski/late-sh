        <mxCell id="bonsai-status" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=top;fontFamily=Courier New;fontSize=10;spacingTop=2;" value="&lt;font color=&quot;#8A7660&quot;&gt;&lt;b&gt;Sapling&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#648C48&quot;&gt;Watered today&lt;/font&gt;" vertex="1">
          <mxGeometry x="940" y="660" width="130" height="30" as="geometry" />
        </mxCell>

